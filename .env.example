# HTTP server
PORT=8080
# Base URL users paste into GitHub webhook settings (no trailing slash)
SERVER_PUBLIC_URL=https://your-host.example.com

# GitHub PAT: repo + pull_requests (read for diffs, write to post review comments)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
# Optional: GitHub Enterprise API root, e.g. https://github.mycompany.com/api/v3
# GITHUB_API_URL=

# SQLite watch list (directory is created automatically when possible)
DB_PATH=./data/watchlist.db

# Optional: require Authorization: Bearer <token> for /api/* management routes
# SERVER_ADMIN_TOKEN=

# Ollama (same as CLI)
OLLAMA_URL=http://localhost:11434
ORB_OLLAMA_MODEL=qwen2.5-coder:7b
# ORB_OLLAMA_TEMPERATURE=0.2
# ORB_OLLAMA_TOP_P=0.9
# ORB_OLLAMA_MAX_TOKENS=2048

# Post review as a GitHub PR comment (default true for server)
# ORB_SERVER_POST_COMMENT=true

# Optional custom prompt template path
# ORB_PROMPT_TEMPLATE=

# Local repo root for full-file context in prompts (optional; GitHub-only reviews work with diff-only)
# ORB_REPO_ROOT=.
